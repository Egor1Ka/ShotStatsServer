# Server (бэкенд; порт должен совпадать с redirect URI в Google Console)
PORT=9000
BASE_URL=http://localhost:9000
API_PREFIX=

# Frontend (CORS + редирект после OAuth; фронт на 5173)
FRONTEND_URL=http://localhost:5173

# MongoDB
DB_URL=mongodb://localhost:27017/basketball

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# JWT
JWT_SECRET=your-secret-min-32-chars
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_DAYS=7

# Cookies (optional)
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=Lax
COOKIE_MAX_AGE_ACCESS_MS=900000
COOKIE_MAX_AGE_REFRESH_MS=604800000


GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:9000/auth/google/callback

JWT_SECRET=super-secret
JWT_REFRESH_SECRET=replace-me
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
